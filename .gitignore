# ─── 비밀키 / 환경 변수 ────────────────────────────────
# 키움 앱키, 디스코드 봇 토큰 등 절대 git에 올리면 안 되는 것들
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── 가상환경 ──────────────────────────────────────────
.venv/
venv/
env/

# ─── uv ───────────────────────────────────────────────
.uv/
# uv.lock은 보통 커밋하지만, 개인용 봇이라 환경 재현이 자유로워도 OK
# 팀 협업이거나 정확한 의존성 핀이 필요하면 이 줄을 주석 처리해서 추적하세요.
uv.lock

# ─── 로그 ─────────────────────────────────────────────
# 거래 정보 등 민감 정보가 포함되므로 git에 올리지 않음
# 단, logs/ 폴더 자체는 유지하기 위해 .gitkeep만 추적
logs/*
!logs/.gitkeep

# ─── IDE / 에디터 ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── 빌드 산출물 ───────────────────────────────────────
build/
dist/
*.spec